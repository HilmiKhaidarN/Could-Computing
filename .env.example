# =============================================================================
# AegisOps Environment Variables
# Copy this file to .env and fill in your values
# =============================================================================

# ─── Database Configuration ──────────────────────────────────────────────────
DATABASE_USER=aegisops
DATABASE_PASSWORD=change_me_in_production
DATABASE_NAME=aegisops_db
DATABASE_PORT=5432
DATABASE_HOST=localhost

# Full connection string (used by Prisma)
DATABASE_URL=postgresql://${DATABASE_USER}:${DATABASE_PASSWORD}@${DATABASE_HOST}:${DATABASE_PORT}/${DATABASE_NAME}

# ─── JWT Authentication ──────────────────────────────────────────────────────
JWT_SECRET=change_me_to_random_string_in_production
JWT_EXPIRES_IN=7d

# ─── AWS Configuration ───────────────────────────────────────────────────────
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key

# S3 Bucket for file uploads
AWS_S3_BUCKET=aegisops-uploads

# CloudFront domain for CDN
AWS_CLOUDFRONT_DOMAIN=d1234567890.cloudfront.net

# ─── Service URLs ────────────────────────────────────────────────────────────
# Backend API URL (used by frontend)
NEXT_PUBLIC_API_URL=http://localhost:4000

# ML Service URL (used by backend)
ML_SERVICE_URL=http://localhost:8000

# ─── Service Ports ───────────────────────────────────────────────────────────
BACKEND_PORT=4000
APP_PORT=3000
ML_SERVICE_PORT=8000

# ─── Node Environment ────────────────────────────────────────────────────────
NODE_ENV=development

# ─── CORS Configuration ──────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ─── Rate Limiting ───────────────────────────────────────────────────────────
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# ─── File Upload ─────────────────────────────────────────────────────────────
MAX_FILE_SIZE=5242880  # 5MB in bytes
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/jpg

# ─── ML Model Configuration ──────────────────────────────────────────────────
MODEL_VERSION=1.0.0
MODEL_PATH=./model/trained_model.pkl

# ─── Production Only (AWS Secrets Manager) ───────────────────────────────────
# In production, these should be fetched from AWS Secrets Manager
# AWS_SECRET_NAME=aegisops/production/secrets
