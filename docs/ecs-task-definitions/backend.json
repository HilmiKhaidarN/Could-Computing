{
  "family": "aegisops-backend",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::ACCOUNT_ID:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::ACCOUNT_ID:role/ecsTaskRole",
  "containerDefinitions": [
    {
      "name": "aegisops-backend",
      "image": "ACCOUNT_ID.dkr.ecr.REGION.amazonaws.com/aegisops-backend:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 3000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "NODE_ENV",  "value": "production" },
        { "name": "PORT",      "value": "3000" }
      ],
      "secrets": [
        { "name": "DATABASE_URL", "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT_ID:secret:aegisops/database-url" },
        { "name": "JWT_SECRET",   "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT_ID:secret:aegisops/jwt-secret" },
        { "name": "ML_SERVICE_URL", "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT_ID:secret:aegisops/ml-service-url" },
        { "name": "S3_BUCKET_NAME",    "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT_ID:secret:aegisops/s3-bucket-name" },
        { "name": "CLOUDFRONT_DOMAIN", "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT_ID:secret:aegisops/cloudfront-domain" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group":         "/ecs/aegisops-backend",
          "awslogs-region":        "REGION",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "healthCheck": {
        "command": ["CMD-SHELL", "node -e \"require('http').get('http://localhost:3000/health', r => process.exit(r.statusCode === 200 ? 0 : 1))\""],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 60
      }
    }
  ]
}
